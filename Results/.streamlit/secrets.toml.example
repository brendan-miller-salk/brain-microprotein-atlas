# Streamlit secrets template.
#
# Copy this file to `.streamlit/secrets.toml` and fill in any overrides.
# `secrets.toml` is git-ignored — never commit real secrets.
#
# The dashboard streams large figure assets (mirror plots, expression
# profiles, smORF cartoons) from a public Hugging Face dataset when the
# directories are not available locally. Override the base URL here if you
# host the assets elsewhere (e.g. a private mirror, S3, Cloudfront).
#
# Default (used if this key is omitted):
#   https://huggingface.co/datasets/brmiller/brain-microprotein-atlas/resolve/main

assets_base_url = "https://huggingface.co/datasets/brmiller/brain-microprotein-atlas/resolve/main"
